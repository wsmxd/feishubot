APP_ENV=dev
LOG_LEVEL=INFO

# Feishu app credentials
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx

# Optional security fields
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# Optional LLM backend settings
LLM_PROVIDER=openai_compatible
LLM_ACTIVE_MODEL=qwen
LLM_BASE_URL=https://api.openai.com
LLM_API_KEY=sk-xxx
LLM_MODEL=gpt-4o-mini
LLM_CHAT_PATH=/v1/chat/completions
LLM_TIMEOUT_SECONDS=60
LLM_SYSTEM_PROMPT=You are a helpful assistant.
# Optional: Multi-model routing. When set, runtime uses LLM_ACTIVE_MODEL from this JSON map.
# Example:
# LLM_MODELS_JSON={"qwen":{"provider":"openai_compatible","base_url":"https://dashscope.aliyuncs.com","api_key":"sk-xxx","model":"qwen-plus","chat_path":"/compatible-mode/v1/chat/completions","timeout_seconds":60,"system_prompt":"You are a helpful assistant."},"deepseek":{"provider":"openai_compatible","base_url":"https://api.deepseek.com","api_key":"sk-yyy","model":"deepseek-chat","chat_path":"/v1/chat/completions","timeout_seconds":60,"system_prompt":"You are a helpful assistant."}}
LLM_MODELS_JSON=

APP_ENV=dev
LOG_LEVEL=INFO

# Feishu app credentials
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx

# Optional security fields
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# Optional LLM backend settings
LLM_PROVIDER=openai_compatible
LLM_ACTIVE_MODEL=qwen
LLM_BASE_URL=https://api.openai.com
LLM_API_KEY=sk-xxx
LLM_MODEL=gpt-4o-mini
LLM_CHAT_PATH=/v1/chat/completions
LLM_TIMEOUT_SECONDS=60
LLM_SYSTEM_PROMPT=You are a helpful assistant.
# Optional: Multi-model routing. Runtime reads model entries from a TOML file.
# Example: LLM_MODELS_CONFIG_PATH=src/feishubot/ai/configs/model_routes.example.toml
LLM_MODELS_CONFIG_PATH=

# Optional override: Tool runtime config TOML path (enabled tools + routing timeout + terminal policy)
# Default is auto-loaded from tools.default.toml in repository root
# Example: AI_TOOLS_CONFIG_PATH=src/feishubot/ai/configs/tools.example.toml
AI_TOOLS_CONFIG_PATH=
